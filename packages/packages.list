# QOSX Package List
# Format: one package per line. Comments allowed.
# This file is the single source of truth for what enters the image.
# To add a package: add it here, commit, push. Pipeline installs it.

# --- Base system ---
systemd
systemd-sysv
dbus
udev
sudo
login
passwd
util-linux
procps
coreutils
findutils
grep
sed
gawk
less
curl
wget
ca-certificates
openssh-client
rsync
tar
gzip
bzip2
xz-utils
live-boot
squashfs-tools
initramfs-tools
locales

# --- Networking ---
iproute2
iputils-ping
net-tools
systemd-resolved
# dhcpcd5 — REMOVED: conflicts with systemd-networkd DHCP
iwd
nftables
dnsutils

# --- Filesystem tools ---
e2fsprogs
dosfstools
parted

# --- Terminal + shell ---
bash
bash-completion
vim
nano
man-db
htop
tmux
tree

# --- Firmware ---
firmware-linux-free
firmware-linux-nonfree

