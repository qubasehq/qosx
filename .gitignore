# Build artifacts — never commit these
output/img/*.img
output/iso/*.iso
output/isowork/
output/*.deb

# Kernel source — too large for git
kernel/linux-*/
kernel/*.tar.xz
kernel/*.tar.gz

# Rootfs build — generated, not source
rootfs/build/
rootfs/modules/

# Repo pool — generated by reprepro
repo/pool/
repo/dists/
repo/db/

# Temp files
*.log
*.tmp
/tmp/

# OS
.DS_Store
Thumbs.db
